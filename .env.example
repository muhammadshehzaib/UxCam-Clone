# ── API ────────────────────────────────────────────────
API_PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://uxclone:uxclone@localhost:5432/uxclone

# Redis
REDIS_URL=redis://localhost:6379

# JWT secret for dashboard read API
DASHBOARD_JWT_SECRET=change-me-in-production

# ── Dashboard ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
DASHBOARD_API_URL=http://localhost:3001

# Dev dashboard token (matches DASHBOARD_JWT_SECRET above)
DASHBOARD_TOKEN=dev-dashboard-token
